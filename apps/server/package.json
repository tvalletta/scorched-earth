{
  "name": "@se/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/index.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@sentry/node",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/core": "^0.16.0",
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "@se/game": "workspace:*",
    "@se/shared": "workspace:*",
    "@sentry/node": "^10.55.0",
    "colyseus": "^0.16.0"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.16.0",
    "@se/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
