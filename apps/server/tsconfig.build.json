{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "../..",
    "outDir": "dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*",
    "../../packages/game/src/**/*",
    "../../packages/shared/src/**/*"
  ],
  "exclude": [
    "tests",
    "dist",
    "node_modules",
    "../../packages/game/src/**/*.test.ts",
    "../../packages/shared/src/**/*.test.ts"
  ]
}
