{
  "name": "scorched-earth",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "test": "pnpm -r test",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "loadtest": "pnpm --filter @se/loadtest start"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.4.0"
  }
}
